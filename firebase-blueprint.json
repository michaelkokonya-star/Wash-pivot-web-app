{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "User information including expertise for recruitment.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "displayName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "expert", "admin"] },
        "expertise": { "type": "string", "description": "Area of specialization (Solar, Water, Sanitation)" },
        "academics": { "type": "string" },
        "academicCredentials": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "type": { "type": "string" },
              "institution": { "type": "string" },
              "specialization": { "type": "string" }
            }
          }
        },
        "bio": { "type": "string" },
        "hasSeenWelcome": { "type": "boolean" },
        "onboardingCompleted": { "type": "boolean" },
        "isApproved": { "type": "boolean", "description": "Whether the user profile is approved by admin" },
        "showContacts": { "type": "boolean", "description": "Whether to reveal contact details to other users" },
        "phoneNumber": { "type": "string" },
        "expertJoinedAt": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "displayName", "email", "role", "isApproved", "showContacts"]
    },
    "Product": {
      "title": "Marketplace Product",
      "description": "Sustainable solutions products with multiple ratings.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number", "description": "Optional: Legacy fixed price or base price" },
        "ratings": { 
          "type": "array", 
          "items": { "type": "string" },
          "description": "Available specs/ratings for this product"
        },
        "category": { "type": "string", "enum": ["Solar", "Water Treatment", "Sanitation"] },
        "subCategory": { "type": "string", "enum": ["Fluoride Removal", "Filtration", "Chlorination", "Solar Panels", "Batteries", "Charge Controller", "Inverter", "Accessories", "Exhaust Services", "None"] },
        "imageUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "category"]
    },
    "Project": {
      "title": "WASH Project",
      "description": "Prospective WASH projects for micro-funding.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "ownerUid": { "type": "string" },
        "ownerName": { "type": "string" },
        "targetFunding": { "type": "number" },
        "currentFunding": { "type": "number" },
        "category": { "type": "string", "enum": ["Solar", "Water Treatment", "Sanitation"] },
        "imageUrl": { "type": "string" },
        "media": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "type": { "type": "string", "enum": ["image", "video"] },
              "url": { "type": "string" }
            },
            "required": ["type", "url"]
          }
        },
        "isApproved": { "type": "boolean", "description": "Whether the project is approved by admin" },
        "isCertified": { "type": "boolean", "description": "Whether the project is vetted and proven to be genuine" },
        "status": { "type": "string", "enum": ["pending", "active", "completed", "rejected"] },
        "milestones": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "title": { "type": "string" },
              "description": { "type": "string" },
              "isCompleted": { "type": "boolean" }
            },
            "required": ["id", "title", "isCompleted"]
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "ownerUid", "targetFunding", "category"]
    },
    "Review": {
      "title": "Product Review",
      "description": "Customer reviews for marketplace products.",
      "type": "object",
      "properties": {
        "productId": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "rating": { "type": "number", "description": "1-5 stars" },
        "comment": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["productId", "userId", "userName", "rating", "comment", "createdAt"]
    },
    "Order": {
      "title": "Marketplace Order",
      "description": "Customer orders from the marketplace.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userEmail": { "type": "string" },
        "items": { "type": "array" },
        "totalAmount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "paid", "processing", "shipped", "out-for-delivery", "delivered", "failed"] },
        "trackingTimeline": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "status": { "type": "string" },
              "label": { "type": "string" },
              "timestamp": { "type": "string", "format": "date-time" },
              "note": { "type": "string" }
            }
          }
        },
        "paymentMethod": { "type": "string", "enum": ["card", "mpesa"] },
        "shippingInfo": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" },
        "paidAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "items", "totalAmount", "status", "paymentMethod", "createdAt"]
    },
    "ServiceProvider": {
      "title": "ServiceProvider",
      "description": "A professional service provider listed on the marketplace",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "category": { "type": "string", "enum": ["Installation", "Maintenance", "Consulting", "Engineering", "Drilling", "Water Treatment", "Solar", "Sanitation"] },
        "subCategory": { "type": "string", "enum": ["Fluoride Removal", "Filtration", "Chlorination", "Solar Panels", "Batteries", "Charge Controller", "Inverter", "Accessories", "Exhaust Services", "None"] },
        "description": { "type": "string" },
        "imageUrl": { "type": "string" },
        "contactEmail": { "type": "string" },
        "contactPhone": { "type": "string" },
        "location": { "type": "string" },
        "isApproved": { "type": "boolean", "description": "Whether the service provider is approved by admin" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "category", "description", "imageUrl", "contactEmail", "contactPhone", "location", "isApproved", "createdAt"]
    },
    "SolarKit": {
      "title": "Custom Solar Kit",
      "description": "A customized solar kit built based on load requirements.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "kitName": { "type": "string" },
        "loadRequirements": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "wattage": { "type": "number" },
              "quantity": { "type": "number" },
              "hoursPerDay": { "type": "number" }
            }
          }
        },
        "selectedHardware": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" },
              "rating": { "type": "string" },
              "price": { "type": "number" },
              "subCategory": { "type": "string" },
              "quantity": { "type": "number" }
            }
          }
        },
        "totalDailyLoadWh": { "type": "number" },
        "totalPeakLoadW": { "type": "number" },
        "totalPriceEstimate": { "type": "number" },
        "expertFee": { "type": "number" },
        "totalProjectCost": { "type": "number" },
        "recommendations": {
          "type": "object",
          "properties": {
            "panelW": { "type": "number" },
            "batteryWh": { "type": "number" },
            "inverterW": { "type": "number" }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "kitName", "loadRequirements", "totalDailyLoadWh", "totalPeakLoadW", "createdAt"]
    },
    "Setting": {
      "title": "System Setting",
      "description": "System-wide configuration settings.",
      "type": "object",
      "properties": {
        "value": { "type": "object", "description": "JSON object containing setting configuration" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "TeamMember": {
      "title": "Team Member",
      "description": "Information about a team member for the Meet the Team section.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "role": { "type": "string" },
        "bio": { "type": "string" },
        "image": { "type": "string" },
        "socials": {
          "type": "object",
          "properties": {
            "twitter": { "type": "string" },
            "linkedin": { "type": "string" },
            "mail": { "type": "string" }
          }
        },
        "order": { "type": "number", "description": "Display order" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "role", "image"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile documents."
    },
    "/products/{productId}": {
      "schema": "Product",
      "description": "Marketplace products."
    },
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Micro-funding projects."
    },
    "/reviews/{reviewId}": {
      "schema": "Review",
      "description": "Product reviews."
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Customer orders."
    },
    "/service_providers/{serviceId}": {
      "schema": "ServiceProvider",
      "description": "Service providers listed on the marketplace."
    },
    "/solar_kits/{kitId}": {
      "schema": "SolarKit",
      "description": "Customized solar kits."
    },
    "/settings/{settingId}": {
      "schema": "Setting",
      "description": "System-wide settings (pricing, delivery, etc.)."
    },
    "/team_members/{memberId}": {
      "schema": "TeamMember",
      "description": "Team members shown on the team page."
    }
  }
}
