{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "User information including expertise for recruitment.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "displayName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "expert", "admin"] },
        "expertise": { "type": "string", "description": "Area of specialization (Solar, Water, Sanitation)" },
        "academics": { "type": "string" },
        "bio": { "type": "string" },
        "hasSeenWelcome": { "type": "boolean" },
        "onboardingCompleted": { "type": "boolean" },
        "isApproved": { "type": "boolean", "description": "Whether the user profile is approved by admin" },
        "showContacts": { "type": "boolean", "description": "Whether to reveal contact details to other users" },
        "phoneNumber": { "type": "string" },
        "expertJoinedAt": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "displayName", "email", "role", "isApproved", "showContacts"]
    },
    "Product": {
      "title": "Marketplace Product",
      "description": "Sustainable solutions products.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string", "enum": ["Solar", "Water", "Sanitation"] },
        "imageUrl": { "type": "string" }
      },
      "required": ["name", "price", "category"]
    },
    "Project": {
      "title": "WASH Project",
      "description": "Prospective WASH projects for micro-funding.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "ownerUid": { "type": "string" },
        "ownerName": { "type": "string" },
        "targetFunding": { "type": "number" },
        "currentFunding": { "type": "number" },
        "category": { "type": "string", "enum": ["Solar", "Water", "Sanitation"] },
        "imageUrl": { "type": "string" },
        "isApproved": { "type": "boolean", "description": "Whether the project is approved by admin" },
        "status": { "type": "string", "enum": ["pending", "active", "completed", "rejected"] },
        "milestones": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "title": { "type": "string" },
              "description": { "type": "string" },
              "isCompleted": { "type": "boolean" }
            },
            "required": ["id", "title", "isCompleted"]
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "ownerUid", "targetFunding", "category"]
    },
    "Review": {
      "title": "Product Review",
      "description": "Customer reviews for marketplace products.",
      "type": "object",
      "properties": {
        "productId": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "rating": { "type": "number", "description": "1-5 stars" },
        "comment": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["productId", "userId", "userName", "rating", "comment", "createdAt"]
    },
    "Order": {
      "title": "Marketplace Order",
      "description": "Customer orders from the marketplace.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userEmail": { "type": "string" },
        "items": { "type": "array" },
        "totalAmount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "paid", "failed", "shipped", "delivered"] },
        "paymentMethod": { "type": "string", "enum": ["card", "mpesa"] },
        "shippingInfo": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" },
        "paidAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "items", "totalAmount", "status", "paymentMethod", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile documents."
    },
    "/products/{productId}": {
      "schema": "Product",
      "description": "Marketplace products."
    },
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Micro-funding projects."
    },
    "/reviews/{reviewId}": {
      "schema": "Review",
      "description": "Product reviews."
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Customer orders."
    }
  }
}
