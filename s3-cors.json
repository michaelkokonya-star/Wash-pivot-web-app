{
  "CORSRules": [
    {
      "Comment": "Allow browser GET/HEAD for public-read objects (product images in marketplace)",
      "AllowedOrigins": ["*"],
      "AllowedMethods": ["GET", "HEAD"],
      "AllowedHeaders": ["*"],
      "ExposeHeaders": ["ETag", "Content-Length", "Content-Type"],
      "MaxAgeSeconds": 3600
    }
  ]
}
